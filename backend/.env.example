DATABASE_URL=postgresql://...
JWT_SECRET=
JWT_REFRESH_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe price IDs — uncomment to override per environment. Defaults baked
# in env.ts target the production System Voidz account; uncomment + set
# these when pointing at a different Stripe account (test/staging/etc.)
# without a code change.
# STRIPE_PRICE_SOLO_MONTH_ID=
# STRIPE_PRICE_SOLO_YEAR_ID=
# STRIPE_PRICE_PRO_MONTH_ID=
# STRIPE_PRICE_PRO_YEAR_ID=
# STRIPE_PRICE_BUSINESS_MONTH_ID=
# STRIPE_PRICE_BUSINESS_YEAR_ID=
# STRIPE_PRICE_BUSINESS_PRO_MONTH_ID=
# STRIPE_PRICE_BUSINESS_PRO_YEAR_ID=
# STRIPE_PRICE_ENTERPRISE_MONTH_ID=
# STRIPE_PRICE_ENTERPRISE_YEAR_ID=
RESEND_API_KEY=
SMTP_FROM=noreply@mycadences.com
APP_URL=https://mycadences.com
PORT=3000
NODE_ENV=production
